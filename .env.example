# Copy this file to .env for local development.
# Never commit .env to version control.

APP_NAME="Arabic NLP API"
APP_VERSION="1.0.0"
ENVIRONMENT=development
DEBUG=true

HOST=0.0.0.0
PORT=8000

# CORS: comma-separated origins, or * for open access
ALLOWED_ORIGINS=*
ALLOWED_METHODS=GET,POST,OPTIONS
ALLOWED_HEADERS=*

# Rate limiting
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_BURST=10/second

# RapidAPI: set this to the proxy secret shown in your RapidAPI dashboard.
# Leave empty to disable the auth gate (useful for development).
RAPIDAPI_PROXY_SECRET=

LOG_LEVEL=INFO
